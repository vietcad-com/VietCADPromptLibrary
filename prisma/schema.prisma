generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tag {
  id        String   @id
  label     String
  group     TagGroup
  createdAt DateTime @default(now()) @map("created_at")

  prompts PromptTag[]

  @@map("tags")
}

model Prompt {
  id        String   @id @default(cuid())
  title     String
  note      String?
  author    String
  createdAt DateTime @default(now()) @map("created_at")

  items PromptItem[]
  tags  PromptTag[]

  @@map("prompts")
}

model PromptItem {
  id       String @id @default(cuid())
  header   String
  content  String
  position Int    @default(0)

  promptId String @map("prompt_id")
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@map("prompt_items")
}

model PromptTag {
  promptId String @map("prompt_id")
  tagId    String @map("tag_id")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
  @@map("prompt_tags")
}

enum TagGroup {
  model
  type
  topic
}
